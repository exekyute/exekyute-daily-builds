---
import "../styles/global.css";
import { SITE, NAV } from "../consts";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: string;
}
const {
  title,
  description = SITE.description,
  image = "/images/og-default.png",
  type = "website",
} = Astro.props;
const pageTitle = title ? `${title} · ${SITE.name}` : `${SITE.name} - ${SITE.tagline}`;
const canonical = new URL(Astro.url.pathname, Astro.site ?? SITE.url).href;
const ogImage = new URL(image, Astro.site ?? SITE.url).href;
const path = Astro.url.pathname;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title ?? SITE.name} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="alternate" type="application/rss+xml" title={SITE.name} href="/rss.xml" />
    <!-- Theme set before paint to avoid a flash. Tiny inline script.
         Always normalizes to one of: light (paper), grid, dark. -->
    <script is:inline>
      (function () {
        var t = null;
        try { t = localStorage.getItem("theme"); } catch (e) {}
        if (t !== "light" && t !== "grid" && t !== "dark") {
          t = matchMedia("(prefers-color-scheme: light)").matches ? "light" : "dark";
        }
        document.documentElement.dataset.theme = t;
      })();
    </script>
  </head>
  <body>
    <a href="#main" class="skip">Skip to content</a>
    <header class="site-header">
      <div class="wrap site-header-inner">
        <a href="/" class="brand" aria-label={`${SITE.name} home`}>
          <span class="brand-mark" aria-hidden="true">◈</span>
          <span class="brand-name">{SITE.name}</span>
        </a>
        <nav class="site-nav" aria-label="Primary">
          {NAV.map((item) => (
            <a
              href={item.href}
              class:list={["site-nav-link", { "is-active": path.startsWith(item.href) && item.href !== "/" }]}
            >{item.label}</a>
          ))}
        </nav>
        <div class="site-header-actions">
          <a href="/guides/" class="site-search-link" aria-label="Search guides">
            <span aria-hidden="true">⌕</span>
          </a>
          <div class="theme-seg" role="group" aria-label="Theme">
            <button type="button" data-set-theme="grid" aria-label="Grid paper theme" title="Grid">
              <span class="seg-hash" aria-hidden="true">#</span>
            </button>
            <button type="button" data-set-theme="light" aria-label="Paper theme" title="Paper">
              <span aria-hidden="true">☀︎</span>
            </button>
            <button type="button" data-set-theme="dark" aria-label="Dark theme" title="Dark">
              <span aria-hidden="true">☾</span>
            </button>
          </div>
        </div>
      </div>
    </header>

    <main id="main">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="wrap site-footer-inner">
        <div>
          <p class="brand"><span class="brand-mark" aria-hidden="true">◈</span> {SITE.name}</p>
          <p class="muted footer-tag">{SITE.tagline}</p>
        </div>
        <nav class="footer-nav" aria-label="Footer">
          {NAV.map((item) => <a href={item.href}>{item.label}</a>)}
          <a href="/rss.xml">RSS</a>
        </nav>
      </div>
      <div class="wrap footer-fine">
        <p class="faint">
          Built with Astro. No trackers, no autoplay video, no anti-adblock walls.
          Template by <a href="https://github.com/exekyute" rel="noopener">Kevin Yu</a>.
        </p>
      </div>
    </footer>

    <script>
      const segs = Array.from(
        document.querySelectorAll<HTMLButtonElement>("[data-set-theme]")
      );
      let fadeTimer: number | undefined;
      function markActive() {
        const current = document.documentElement.dataset.theme;
        segs.forEach((b) =>
          b.setAttribute("aria-pressed", b.dataset.setTheme === current ? "true" : "false")
        );
      }
      segs.forEach((b) => {
        b.addEventListener("click", () => {
          const root = document.documentElement;
          // Brief .theme-fade class lets colors cross-fade (see global.css).
          if (!matchMedia("(prefers-reduced-motion: reduce)").matches) {
            root.classList.add("theme-fade");
            window.clearTimeout(fadeTimer);
            fadeTimer = window.setTimeout(() => root.classList.remove("theme-fade"), 400);
          }
          const next = b.dataset.setTheme!;
          root.dataset.theme = next;
          try { localStorage.setItem("theme", next); } catch (e) {}
          markActive();
        });
      });
      markActive();
    </script>

    <style>
      .skip {
        position: absolute; left: -999px; top: 0.5rem; z-index: 200;
        background: var(--accent); color: var(--accent-ink); padding: 0.5rem 1rem; border-radius: 8px;
      }
      .skip:focus { left: 0.5rem; }

      .site-header {
        position: sticky; top: 0; z-index: 50;
        background: color-mix(in srgb, var(--ink-900) var(--header-veil), transparent);
        backdrop-filter: blur(10px);
        border-bottom: 1px solid var(--line);
      }
      .site-header-inner {
        display: flex; align-items: center; gap: var(--space-3);
        height: 4rem;
      }
      .brand { display: inline-flex; align-items: center; gap: 0.5rem; font-weight: 800; color: var(--text); font-size: 1.1rem; }
      .brand:hover { text-decoration: none; }
      .brand-mark { color: var(--accent); }
      .site-nav { display: flex; gap: 0.35rem; margin-left: auto; }
      .site-nav-link {
        color: var(--text-soft); padding: 0.5rem 0.8rem; border-radius: 999px; font-weight: 600;
      }
      .site-nav-link:hover { color: var(--text); background: var(--ink-700); text-decoration: none; }
      .site-nav-link.is-active { color: var(--accent); }
      .site-header-actions { display: flex; align-items: center; gap: 0.4rem; }
      .site-search-link {
        width: 2.4rem; height: 2.4rem; display: grid; place-items: center; border-radius: 999px;
        background: transparent; border: 1px solid var(--line); color: var(--text-soft); cursor: pointer; font-size: 1.1rem;
      }
      .site-search-link:hover { color: var(--text); background: var(--ink-700); text-decoration: none; }

      .theme-seg {
        display: inline-flex; border: 1px solid var(--line); border-radius: 999px;
        overflow: hidden; background: transparent;
      }
      .theme-seg button {
        width: 2.2rem; height: 2.4rem; display: grid; place-items: center;
        background: transparent; border: none; color: var(--text-soft);
        cursor: pointer; font-size: 1rem; line-height: 1;
      }
      .theme-seg button + button { border-left: 1px solid var(--line); }
      .theme-seg button:hover { color: var(--text); background: var(--ink-700); }
      .theme-seg button[aria-pressed="true"] { color: var(--accent); background: var(--ink-700); }
      .seg-hash { font-family: var(--mono); font-size: 0.95rem; font-weight: 700; }

      .site-footer { border-top: 1px solid var(--line); margin-top: var(--space-6); padding: var(--space-4) 0 var(--space-3); background: var(--ink-850); }
      .site-footer-inner { display: flex; flex-wrap: wrap; gap: var(--space-4); justify-content: space-between; }
      .footer-tag { margin: 0.3rem 0 0; max-width: 26rem; }
      .footer-nav { display: flex; flex-wrap: wrap; gap: 0.4rem 1rem; align-items: flex-start; }
      .footer-nav a { color: var(--text-soft); }
      .footer-fine { margin-top: var(--space-3); padding-top: var(--space-3); border-top: 1px solid var(--line); }

      @media (max-width: 40rem) {
        .site-nav { gap: 0; margin-left: auto; }
        .site-nav-link { padding: 0.5rem 0.55rem; font-size: 0.9rem; }
        .brand-name { display: none; }
        /* The Guides page has the search box; drop the duplicate icon on phones. */
        .site-search-link { display: none; }
      }
    </style>
  </body>
</html>
