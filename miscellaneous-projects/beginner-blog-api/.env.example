# Postgres connection string. From Render/Railway dashboard or a local install.
DATABASE_URL="postgresql://user:password@localhost:5432/blog_api?schema=public"

# Secret used to sign JWTs. Use any long random string; on Linux/Mac you can
# generate one with: openssl rand -base64 32
JWT_SECRET="replace-me-with-a-long-random-string"

# Port the server listens on. Render and Railway set this automatically.
PORT=3000
