# generated output (regenerated by run.py; golden lives in expected/)
out/

# local working databases
*.duckdb
*.db

# python caches
__pycache__/

# local styled-docs preview (not part of the build)
_preview/

# local BI working files: keep the .twb, never the packaged .twbx
bi/README.md
*.twbx

# Power BI local state (Microsoft's own gitignore defaults for .pbip projects)
**/.pbi/localSettings.json
**/.pbi/cache.abf
