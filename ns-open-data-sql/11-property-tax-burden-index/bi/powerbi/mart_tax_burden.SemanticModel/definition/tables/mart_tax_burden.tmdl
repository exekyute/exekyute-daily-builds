	partition mart_tax_burden = m
		mode: import
		source =
				let
				  Source = Csv.Document(File.Contents("..\exports\mart_tax_burden.csv"), [Delimiter = ",", Columns = 10, QuoteStyle = QuoteStyle.None]),
				  #"Promoted headers" = Table.PromoteHeaders(Source, [PromoteAllScalars = true]),
