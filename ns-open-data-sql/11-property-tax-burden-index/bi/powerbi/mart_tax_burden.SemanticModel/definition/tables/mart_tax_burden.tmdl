table mart_tax_burden
	lineageTag: d2f1158c-59d8-48e8-b38e-2a5b12748d21

	measure 'Total Spread' = SUM ( mart_tax_burden[spread] )
		lineageTag: 691d4feb-9b65-4170-8d43-841869005d5d

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Latest Year Overall' =
			
			CALCULATE ( MAX ( mart_tax_burden[year_start] ), ALL ( mart_tax_burden ) )
		formatString: 0
		lineageTag: 7442722f-c184-4453-9328-91df5166f3ec

	measure 'Spread Prev Year' =
			
			VAR CurrentYear = MAX ( mart_tax_burden[year_start] )
			RETURN
			    CALCULATE (
			        SUM ( mart_tax_burden[spread] ),
			        REMOVEFILTERS ( mart_tax_burden[year_start] ),
			        mart_tax_burden[year_start] = CurrentYear - 1
			    )
		lineageTag: fb646168-9b5c-4f69-8253-36637092cb3f

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Spread YoY Change' =
			
			VAR Prev = [Spread Prev Year]
			RETURN
			    IF ( ISBLANK ( Prev ), BLANK (), [Total Spread] - Prev )
		lineageTag: 44e91f66-ee11-4d75-b834-60065cc4d55f

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Widest Spread' =
			
			VAR LatestYear = [Latest Year Overall]
			RETURN
			    CALCULATE (
			        MAX ( mart_tax_burden[spread] ),
			        ALL ( mart_tax_burden ),
			        mart_tax_burden[year_start] = LatestYear
			    )
		formatString: 0.0000
		lineageTag: d22479ab-958c-41b6-8997-de7ea3c1bd6b

	measure 'Widest Spread Municipality' =
			
			VAR LatestYear = [Latest Year Overall]
			VAR LatestRows =
			    FILTER ( ALL ( mart_tax_burden ), mart_tax_burden[year_start] = LatestYear )
			VAR TopRow =
			    TOPN ( 1, LatestRows, mart_tax_burden[spread], DESC, mart_tax_burden[municipality], ASC )
			RETURN
			    CONCATENATEX ( TopRow, mart_tax_burden[municipality], ", " )
		lineageTag: 2ac2547a-ff7e-40a8-8fd4-0e4b5a9e4727

	measure 'Median Spread Latest Year' =
			
			VAR LatestYear = [Latest Year Overall]
			RETURN
			    CALCULATE (
			        MEDIAN ( mart_tax_burden[spread] ),
			        ALL ( mart_tax_burden ),
			        mart_tax_burden[year_start] = LatestYear
			    )
		formatString: 0.0000
		lineageTag: 83ec6a63-e78f-4f6e-8bd5-7dfc886bb606

	measure 'Spread Rank' =
			
			RANKX (
			    ALLSELECTED ( mart_tax_burden[municipality] ),
			    CALCULATE ( SUM ( mart_tax_burden[spread] ) ),
			    ,
			    DESC,
			    Skip
			)
		formatString: 0
		lineageTag: 82dc8fac-3dbe-4af6-88ce-1520f8a69c1b

